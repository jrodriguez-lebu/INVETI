APP_NAME=INVETI
APP_ENV=production
APP_KEY=                          # Generar con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://inveti.municipalidadlebu.cl

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                     # Nombre del servicio MySQL en Dokploy
DB_PORT=3306
DB_DATABASE=inveti
DB_USERNAME=inveti_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Sesiones / Caché / Cola ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Correo (SMTP municipalidad) ───────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.municipalidadlebu.cl
MAIL_PORT=587
MAIL_USERNAME=inveti@municipalidadlebu.cl
MAIL_PASSWORD=CAMBIAR_POR_PASSWORD_CORREO
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=inveti@municipalidadlebu.cl
MAIL_FROM_NAME="INVETI Municipalidad de Lebu"

VITE_APP_NAME="${APP_NAME}"
